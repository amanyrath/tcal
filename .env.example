# Copy to .env for local overrides. All values are optional.

# Days of events to fetch ahead (Vercel Hobby: keep <= 30 for the 10s timeout).
DAYS_AHEAD=30

# How long (seconds) the edge/server caches each feed before refetching.
CACHE_TTL_SECONDS=3600

# Comma-separated gym keys to fetch/serve. Unset = all 17 gyms. Fewer gyms means
# faster fetches, smaller payloads, and a smaller shared-cache snapshot.
# GYMS=pacific-pipe,gwpower-co,ironworks,mission-cliffs

# Comma-separated hosts allowed in generated absolute URLs (Host-header guard).
# Leave unset to trust the request host (fine for local dev).
# ALLOWED_HOSTS=your-app.vercel.app

# Optional: share the cached feed across serverless instances to avoid cold
# refetches. Requires the optional 'redis' package. Unset = in-memory only.
# REDIS_URL=redis://localhost:6379/0

# Logging verbosity: DEBUG, INFO, WARNING, ERROR (default INFO).
# LOG_LEVEL=INFO

# Optional error tracking. Requires the optional 'sentry-sdk' package.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
